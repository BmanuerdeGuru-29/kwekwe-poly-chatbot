# API Configuration
DEBUG=true
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ADMIN_API_KEY=change-me-for-admin-access

# LLM Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
# For local LLM alternatives:
# OPENAI_BASE_URL=http://localhost:8000/v1

# Vector Database
CHROMA_DB_PATH=./data/vector_store
EMBEDDING_MODEL=all-MiniLM-L6-v2
UPLOAD_DIR=./data/uploads
FEEDBACK_FILE=./data/feedback/feedback.jsonl
ANALYTICS_FILE=./data/analytics/chat_events.jsonl
WEBSITE_SYNC_SEEDS=https://www.kwekwepoly.ac.zw/,https://www.kwekwepoly.ac.zw/portal.php,https://www.kwekwepoly.ac.zw/hostel.php,https://www.kwekwepoly.ac.zw/commerce.php,https://apply.kwekwepoly.ac.zw/
MAX_WEBSITE_SYNC_PAGES=25

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token

# Redis
REDIS_URL=redis://localhost:6379

# PHP Integration
PHP_API_BASE_URL=http://localhost/php-api
PHP_API_KEY=your-php-api-key

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
