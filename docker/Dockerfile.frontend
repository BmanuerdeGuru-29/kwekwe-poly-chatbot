FROM nginx:alpine

# Serve the static frontend directory directly
COPY frontend/ /usr/share/nginx/html/

# Expose port
EXPOSE 80

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget -q -O- http://localhost/ > /dev/null

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
